spawn-at-startup "noctalia-shell"
//////////////
// HARDWARE //
//////////////
input {
    keyboard {
        xkb {
            layout "us,ru"
            options "grp:alt_shift_toggle"
        }
    }
    touchpad {
        off
    }
    focus-follows-mouse max-scroll-amount="0%"
}
output "eDP-1" {
    scale 1.0
}
////////////
// LAYOUT //
////////////
layout {
    gaps 8
    center-focused-column "never"
    always-center-single-column
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }
    preset-window-heights {
        proportion 0.5
        proportion 1.0
    }
    default-column-width {
        proportion 1.0
    }
    focus-ring {
        width 4
        active-gradient from="#ebbcba" to="#9ccfd8" angle=45
    }
    border {
        off
    }
    shadow {
        off
    }
    insert-hint {
        gradient from="#ebbcba" to="#9ccfd8" angle=45
    }
}
////////////////
// WORKSPACES //
////////////////
workspace "browser"
window-rule {
    match title="Picture-in-Picture" app-id="zen-beta"
    default-column-width {
        fixed 560
    }
    default-window-height {
        fixed 310
    }
    open-floating true
}
window-rule {
    match title="Library" app-id="zen-beta"
    default-column-width {
        fixed 800
    }
    default-window-height {
        fixed 620
    }
    open-floating true
}
window-rule {
    match title="Generate Password" app-id="org.keepassxc.KeePassXC"
		open-floating true
}
window-rule {
    match title="Zen Browser" app-id="zen-beta"
    open-on-workspace "browser"
    open-maximized-to-edges true
}
//////////
// MISC //
//////////
gestures {
	hot-corners {
		off
	}
}
clipboard {
    disable-primary
}
screenshot-path "~/screenshots/%Y-%m-%d_%H-%M-%S.png"
//////////
overview {
    zoom 0.65
    backdrop-color "#191724"
    workspace-shadow {
        off
    }
}
hotkey-overlay {
    skip-at-startup
}
recent-windows {
    off
}
//////////
window-rule {
    match app-id="org\\.gnome\\..*"
    open-floating true
}
window-rule {
    match app-id="^winboat"
    open-fullscreen false
    open-maximized true
}
//////////
prefer-no-csd
window-rule {
    geometry-corner-radius 0
    clip-to-geometry true
}
///////////
// BINDS //
///////////
binds {
    // Mod-?
    Mod+Shift+Slash hotkey-overlay-title="❓ Help · Hotkey Overlay" {
        show-hotkey-overlay
    }
    Mod+Return hotkey-overlay-title="🧰 Apps · Terminal" {
        spawn "alacritty"
    }
    Mod+Space hotkey-overlay-title="🧰 Apps · Launcher" {
        spawn "fuzzel"
    }
    Mod+E hotkey-overlay-title="🧰 Apps · File Explorer" {
        spawn "nautilus"
    }
    // Mod+Alt+L hotkey-overlay-title="🔒 System · Lock Screen" {
    //     spawn "swaylock"
    // }
    XF86AudioRaiseVolume allow-when-locked=true {
        spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02+ -l 1.0"
    }
    XF86AudioLowerVolume allow-when-locked=true {
        spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.02-"
    }
    XF86AudioMute allow-when-locked=true {
        spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    }
    XF86AudioMicMute allow-when-locked=true {
        spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"
    }
    // XF86AudioPlay allow-when-locked=true {
    //     spawn-sh "playerctl play-pause"
    // }
    // XF86AudioStop allow-when-locked=true {
    //     spawn-sh "playerctl stop"
    // }
    // XF86AudioPrev allow-when-locked=true {
    //     spawn-sh "playerctl previous"
    // }
    // XF86AudioNext allow-when-locked=true {
    //     spawn-sh "playerctl next"
    // }
    XF86MonBrightnessUp allow-when-locked=true {
        spawn "brightnessctl" "--class=backlight" "set" "+10%"
    }
    XF86MonBrightnessDown allow-when-locked=true {
        spawn "brightnessctl" "--class=backlight" "set" "10%-"
    }

    Mod+O repeat=false hotkey-overlay-title="🗂️ Workspace · Overview" {
        toggle-overview
    }
    Mod+W repeat=false hotkey-overlay-title="🪟 Window · Close" {
        close-window
    }
    Mod+Left hotkey-overlay-title="🧱 Column · Focus Left" {
        focus-column-left
    }
    Mod+Down hotkey-overlay-title="🪟 Window · Focus Down" {
        focus-window-down
    }
    Mod+Up hotkey-overlay-title="🪟 Window · Focus Up" {
        focus-window-up
    }
    Mod+Right hotkey-overlay-title="🧱 Column · Focus Right" {
        focus-column-right
    }
    Mod+H hotkey-overlay-title="🧱 Column · Focus Left" {
        focus-column-left
    }
    Mod+J hotkey-overlay-title="🪟 Window · Focus Down" {
        focus-window-down
    }
    Mod+K hotkey-overlay-title="🪟 Window · Focus Up" {
        focus-window-up
    }
    Mod+L hotkey-overlay-title="🧱 Column · Focus Right" {
        focus-column-right
    }
    Mod+Shift+Left hotkey-overlay-title="🧱 Column · Move Left" {
        move-column-left
    }
    Mod+Shift+Down hotkey-overlay-title="🪟 Window · Move Down" {
        move-window-down
    }
    Mod+Shift+Up hotkey-overlay-title="🪟 Window · Move Up" {
        move-window-up
    }
    Mod+Shift+Right hotkey-overlay-title="🧱 Column · Move Right" {
        move-column-right
    }
    Mod+Shift+H hotkey-overlay-title="🧱 Column · Move Left" {
        move-column-left
    }
    Mod+Shift+J hotkey-overlay-title="🪟 Window · Move Down" {
        move-window-down
    }
    Mod+Shift+K hotkey-overlay-title="🪟 Window · Move Up" {
        move-window-up
    }
    Mod+Shift+L hotkey-overlay-title="🧱 Column · Move Right" {
        move-column-right
    }
    Mod+1 hotkey-overlay-title="🗂️ Workspace · Focus" {
        focus-workspace 1
    }

    Mod+2 {
        focus-workspace 2
    }
    Mod+3 {
        focus-workspace 3
    }
    Mod+4 {
        focus-workspace 4
    }
    Mod+5 {
        focus-workspace 5
    }
    Mod+6 {
        focus-workspace 6
    }
    Mod+7 {
        focus-workspace 7
    }
    Mod+8 {
        focus-workspace 8
    }
    Mod+9 {
        focus-workspace 9
    }
    Mod+Shift+1 hotkey-overlay-title="🗂️ Workspace · Move Column" {
        move-column-to-workspace 1
    }
    Mod+Shift+2 {
        move-column-to-workspace 2
    }
    Mod+Shift+3 {
        move-column-to-workspace 3
    }
    Mod+Shift+4 {
        move-column-to-workspace 4
    }
    Mod+Shift+5 {
        move-column-to-workspace 5
    }
    Mod+Shift+6 {
        move-column-to-workspace 6
    }
    Mod+Shift+7 {
        move-column-to-workspace 7
    }
    Mod+Shift+8 {
        move-column-to-workspace 8
    }
    Mod+Shift+9 {
        move-column-to-workspace 9
    }
    Mod+BracketLeft hotkey-overlay-title="🧱 Column · Consume/Expel Left" {
        consume-or-expel-window-left
    }
    Mod+BracketRight hotkey-overlay-title="🧱 Column · Consume/Expel Right" {
        consume-or-expel-window-right
    }
    Mod+Comma hotkey-overlay-title="🧱 Column · Consume Window" {
        consume-window-into-column
    }
    Mod+Period hotkey-overlay-title="🧱 Column · Expel Window" {
        expel-window-from-column
    }
    Mod+R hotkey-overlay-title="📐 Layout · Preset Column Width" {
        switch-preset-column-width
    }
    Mod+Shift+R hotkey-overlay-title="📐 Layout · Preset Window Height" {
        switch-preset-window-height
    }
    Mod+Ctrl+R hotkey-overlay-title="📐 Layout · Reset Window Height" {
        reset-window-height
    }
    Mod+F hotkey-overlay-title="📐 Layout · Maximize Column" {
        maximize-column
    }
    Mod+Shift+F hotkey-overlay-title="📐 Layout · Fullscreen" {
        fullscreen-window
    }
    Mod+Ctrl+F hotkey-overlay-title="📐 Layout · Expand Column" {
        expand-column-to-available-width
    }
    Mod+M hotkey-overlay-title="📐 Layout · Maximize to Edges" {
        maximize-window-to-edges
    }
    Mod+C hotkey-overlay-title="📐 Layout · Center Column" {
        center-column
    }
    Mod+Minus hotkey-overlay-title="📐 Layout · Window Height +5%" {
        set-window-height "+5%"
    }
    Mod+Shift+Minus hotkey-overlay-title="📐 Layout · Window Height -5%" {
        set-window-height "-5%"
    }
    Mod+Equal hotkey-overlay-title="📐 Layout · Column Width +5%" {
        set-column-width "+5%"
    }
    Mod+Shift+Equal hotkey-overlay-title="📐 Layout · Column Width -5%" {
        set-column-width "-5%"
    }
    Mod+V hotkey-overlay-title="🪟 Window · Toggle Floating" {
        toggle-window-floating
    }
    Mod+Shift+V hotkey-overlay-title="🪟 Window · Focus Floating/Tiling" {
        switch-focus-between-floating-and-tiling
    }
    Mod+Q hotkey-overlay-title="📐 Layout · Toggle Tabbed Column" {
        toggle-column-tabbed-display
    }
    Print hotkey-overlay-title="📸 Screenshot · Area" {
        screenshot
    }
    Ctrl+Print hotkey-overlay-title="📸 Screenshot · Screen" {
        screenshot-screen
    }
    Alt+Print hotkey-overlay-title="📸 Screenshot · Window" {
        screenshot-window
    }
    Mod+Shift+E hotkey-overlay-title="⏻ System · Quit Niri" {
        quit
    }
    Ctrl+Alt+Delete hotkey-overlay-title="⏻ System · Quit Niri" {
        quit
    }
}
